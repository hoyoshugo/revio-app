# ============================================================
# Revio Backend — Variables de entorno
# Copiar a .env y completar valores reales
# ============================================================

# LOBBY PMS
LOBBY_TOKEN_ISLA_PALMA=your_lobbypms_token_isla_palma
LOBBY_TOKEN_TAYRONA=your_lobbypms_token_tayrona
LOBBY_API_URL=https://api.lobbypms.com

# WOMPI — ISLA PALMA
WOMPI_PUBLIC_KEY_ISLA=pub_prod_...
WOMPI_PRIVATE_KEY_ISLA=prv_prod_...

# WOMPI — TAYRONA
WOMPI_PUBLIC_KEY_TAYRONA=pub_prod_...
WOMPI_PRIVATE_KEY_TAYRONA=prv_prod_...
WOMPI_API_URL=https://production.wompi.co/v1

# WHATSAPP (dejar WHATSAPP_TOKEN=pendiente hasta obtener token)
WHATSAPP_NUMBER=+57300XXXXXXX
WHATSAPP_TOKEN=pendiente
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=your_phone_id

# ANTHROPIC
ANTHROPIC_API_KEY=sk-ant-api03-...

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=sb_publishable_...

# JWT
JWT_SECRET=change_this_to_random_secret_min_32_chars

# AES-256 para cifrado de API keys de clientes
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_char_key_here

# SUPER ADMIN
SUPERADMIN_EMAIL=admin@yourcompany.com
SUPERADMIN_PASSWORD=your_superadmin_password
JWT_SUPERADMIN_SECRET=change_this_to_random_secret_min_32_chars

# SERVIDOR
PORT=3001
NODE_ENV=production

# EMAIL (opcional — fallback cuando WhatsApp no disponible)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=pendiente
SMTP_PASS=pendiente
EMAIL_FROM=Revio <noreply@yourcompany.com>

# ALERTAS (números de WhatsApp para notificaciones internas)
ALERT_WHATSAPP=+57300XXXXXXX
LEARNING_WHATSAPP_1=+57300XXXXXXX
LEARNING_WHATSAPP_2=+57300XXXXXXX
ESCALATION_WHATSAPP_1=+57300XXXXXXX
ESCALATION_WHATSAPP_2=+57300XXXXXXX

# META (Instagram + Facebook — opcional)
META_APP_SECRET=pendiente
META_VERIFY_TOKEN=your_verify_token

# BOOKING.COM (opcional)
BOOKING_WEBHOOK_SECRET=pendiente

# FRONTEND URL (Railway URL en producción)
FRONTEND_URL=https://your-frontend.railway.app
